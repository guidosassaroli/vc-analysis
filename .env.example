# ─── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Optional ─────────────────────────────────────────────────────────────────
# Claude model to use for scoring and memo generation
# Default: claude-sonnet-4-6 (latest Sonnet)
# Alternatives: claude-opus-4-6 (most capable), claude-haiku-4-5-20251001 (fastest/cheapest)
ANTHROPIC_MODEL=claude-sonnet-4-6

# SQLite database path (relative to backend/)
DATABASE_URL=sqlite:///./dealflow.db
